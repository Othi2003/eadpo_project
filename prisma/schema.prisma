generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])

  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  @@map("user")
}

model Pasteur {
  id        String   @id @default(cuid())
  nom       String
  prenom    String
  titre     String
  photo     String
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pasteur")
}

model Structure {
  id          String               @id @default(cuid())
  slug        String               @unique
  sigle       String
  nom         String
  description String?
  logo        String?
  ordre       Int                  @default(0)
  publie      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  membres     MembreCoordination[]
  objectifs   ObjectifStructure[]
  images      ImageStructure[]

  @@map("structure")
}

model ObjectifStructure {
  id          String    @id @default(cuid())
  contenu     String
  ordre       Int       @default(0)
  structureId String
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade)

  @@map("objectif_structure")
}

model ImageStructure {
  id          String    @id @default(cuid())
  url         String
  ordre       Int       @default(0)
  structureId String
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade)

  @@map("image_structure")
}

model MembreCoordination {
  id          String    @id @default(cuid())
  nom         String
  prenom      String
  titre       String
  photo       String
  ordre       Int       @default(0)
  structureId String
  structure   Structure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("membre_coordination")
}

model Groupe {
  id          String             @id @default(cuid())
  slug        String             @unique
  nom         String
  description String?
  logo        String?
  ordre       Int                @default(0)
  publie      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  objectifs   ObjectifGroupe[]
  images      ImageGroupe[]

  @@map("groupe")
}

model ObjectifGroupe {
  id       String  @id @default(cuid())
  contenu  String
  ordre    Int     @default(0)
  groupeId String
  groupe   Groupe  @relation(fields: [groupeId], references: [id], onDelete: Cascade)

  @@map("objectif_groupe")
}

model ImageGroupe {
  id       String  @id @default(cuid())
  url      String
  ordre    Int     @default(0)
  groupeId String
  groupe   Groupe  @relation(fields: [groupeId], references: [id], onDelete: Cascade)

  @@map("image_groupe")
}

model Culte {
  id        String        @id @default(cuid())
  slug      String        @unique
  titre     String
  date      DateTime
  audio     String?
  video     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  etapes    EtapeCulte[]
  images    CulteImage[]

  @@map("culte")
}

model EtapeCulte {
  id          String   @id @default(cuid())
  numero      Int
  titre       String
  description String
  culteId     String
  culte       Culte    @relation(fields: [culteId], references: [id], onDelete: Cascade)

  @@map("etape_culte")
}

model CulteImage {
  id        String   @id @default(cuid())
  url       String
  ordre     Int      @default(0)
  culteId   String
  culte     Culte    @relation(fields: [culteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("culte_image")
}

model Information {
  id        String   @id @default(cuid())
  titre     String
  contenu   String
  image     String?
  ordre     Int      @default(0)
  publie    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("information")
}

model DossierMedia {
  id          String         @id @default(cuid())
  nom         String
  slug        String         @unique
  type        DossierType    @default(EVENEMENT)
  culteId     String?        @unique
  parentId    String?
  parent      DossierMedia?  @relation("SousDossiers", fields: [parentId], references: [id], onDelete: Cascade)
  sousDossiers DossierMedia[] @relation("SousDossiers")
  medias      MediaFichier[]
  ordre       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("dossier_media")
}

model MediaFichier {
  id         String       @id @default(cuid())
  url        String
  type       FichierType
  nom        String?
  ordre      Int          @default(0)
  dossierId  String
  dossier    DossierMedia @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@map("media_fichier")
}

enum DossierType {
  CULTE
  EVENEMENT
}

enum FichierType {
  PHOTO
  VIDEO
}

model SlideHero {
  id        String   @id @default(cuid())
  image     String
  label     String?
  texte     String?
  reference String?
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("slide_hero")
}

model Programme {
  id        String   @id @default(cuid())
  jour      String
  heure     String
  titre     String
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("programme")
}

model JalonHistoire {
  id        String   @id @default(cuid())
  annee     String
  texte     String
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jalon_histoire")
}

model APropos {
  id      String @id @default(cuid())
  vision  String
  mission String
  valeurs String

  @@map("a_propos")
}